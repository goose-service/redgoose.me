{
  "name": "redgoose.me",
  "version": "6.1.0",
  "repository": "https://github.com/goose-service/redgoose.me.git",
  "author": "redgoose <scripter@me.com>",
  "type": "module",
  "license": "ISC",
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"bun run --bun server/main.js\" \"bunx --bun vite\"",
    "dev:server": "NODE_ENV=development bun run --bun server/main.js",
    "prebuild": "rm -rf ./dist",
    "build": "bunx --bun vite build && bun run --bun ./server/build.js",
    "build:server": "rm -rf ./dist && bun run --bun ./server/build.js",
    "build:client": "rm -rf ./dist && bunx --bun vite build",
    "prod:preview": "NODE_ENV=production bun run --bun dist/main.js"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "dependencies": {
    "@kitajs/html": "^4.2.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@vitejs/plugin-vue": "^6.0.8",
    "auto-writer": "^1.2.5",
    "concurrently": "^10.0.3",
    "isbot": "^5.2.1",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.6",
    "ofetch": "^1.5.1",
    "sass": "^1.101.0",
    "terser": "^5.49.0",
    "vite": "^8.1.5",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0"
  }
}
